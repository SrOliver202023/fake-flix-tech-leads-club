{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "moduleNameMapper": {
    "@src/(.*)": "<rootDir>/src/$1",
    "(.*)/prisma/client/(.*)\\.js$": "$1/prisma/client/$2",
    "^generated/(.*)$": "<rootDir>/generated/$1"
  },
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}
